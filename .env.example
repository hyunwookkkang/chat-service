# ===== PostgreSQL =====
# docker-compose의 postgres 서비스 및 DATABASE_URL 오버라이드에 사용된다.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="chat_service"

# 로컬 개발용 DATABASE_URL (host = localhost)
# [중요] docker-compose로 실행할 때는 app 컨테이너에서 DB host가 localhost가 아니라
#        postgres 서비스명이어야 한다. docker-compose.yml의 app.environment에서
#        DATABASE_URL을 "...@postgres:5432/..." 로 오버라이드하므로 이 파일은 그대로 두면 된다.
#        (로컬에서 npm run start:dev로 띄울 때만 아래 localhost 값이 사용된다.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chat_service?schema=public"

# ===== JWT =====
# Access Token 서명 secret (짧은 만료)
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
# Refresh Token 서명 secret (별도 값 권장)
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# ===== Server =====
PORT=3000

# ===== Admin Seed (선택) =====
# prisma/seed.ts가 우선 사용하고, 없으면 기본값(admin@test.com / admin1234)으로 fallback.
# [보안] 실제 배포 시에는 반드시 강력한 값으로 주입할 것.
ADMIN_SEED_EMAIL="admin@test.com"
ADMIN_SEED_PASSWORD="admin1234"
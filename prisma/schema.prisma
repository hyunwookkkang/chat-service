// Prisma schema for chat-service
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum ChatRoomStatus {
  WAITING
  ACTIVE
  COMPLETED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  name      String
  createdAt DateTime @default(now())

  chatRoomsAsUser  ChatRoom[] @relation("UserChatRooms")
  chatRoomsAsAgent ChatRoom[] @relation("AgentChatRooms")
  messages         Message[]

  @@map("users")
}

model ChatRoom {
  id        String         @id @default(uuid())
  userId    String
  agentId   String?
  status    ChatRoomStatus @default(WAITING)
  createdAt DateTime       @default(now())
  // WAITING -> ACTIVE로 매칭된 시각 (대기시간/상담시간 통계 계산용)
  matchedAt DateTime?
  closedAt  DateTime?

  user     User      @relation("UserChatRooms", fields: [userId], references: [id])
  agent    User?     @relation("AgentChatRooms", fields: [agentId], references: [id])
  messages Message[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@map("chat_rooms")
}

model Message {
  id         String   @id @default(uuid())
  chatRoomId String
  senderId   String
  content    String
  createdAt  DateTime @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender   User     @relation(fields: [senderId], references: [id])

  @@index([chatRoomId])
  @@map("messages")
}